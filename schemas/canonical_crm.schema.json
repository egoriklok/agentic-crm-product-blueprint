{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-crm.local/schemas/canonical_crm.schema.json",
  "title": "Canonical Agentic CRM Dataset",
  "type": "object",
  "required": ["organization", "sources", "products", "accounts", "contacts", "opportunities", "agent_runs", "audit_events"],
  "properties": {
    "organization": { "$ref": "#/$defs/Organization" },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/Source" }
    },
    "products": {
      "type": "array",
      "items": { "$ref": "#/$defs/Product" }
    },
    "accounts": {
      "type": "array",
      "items": { "$ref": "#/$defs/Account" }
    },
    "contacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/Contact" }
    },
    "opportunities": {
      "type": "array",
      "items": { "$ref": "#/$defs/Opportunity" }
    },
    "agent_runs": {
      "type": "array",
      "items": { "$ref": "#/$defs/AgentRun" }
    },
    "audit_events": {
      "type": "array",
      "items": { "$ref": "#/$defs/AuditEvent" }
    }
  },
  "$defs": {
    "EntityBase": {
      "type": "object",
      "required": ["id", "source_ids", "confidence", "sensitivity", "created_at", "updated_at"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "source_ids": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "sensitivity": { "enum": ["public", "internal", "confidential", "pii"] },
        "created_at": { "type": "string" },
        "updated_at": { "type": "string" }
      }
    },
    "Organization": {
      "allOf": [
        { "$ref": "#/$defs/EntityBase" },
        {
          "type": "object",
          "required": ["name", "website", "target_region"],
          "properties": {
            "name": { "type": "string" },
            "website": { "type": "string" },
            "target_region": { "type": "string" },
            "positioning": { "type": "string" }
          }
        }
      ]
    },
    "Source": {
      "type": "object",
      "required": ["id", "kind", "uri", "retrieved_at", "trust_level"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "enum": ["url", "file", "manual_note", "api", "database"] },
        "uri": { "type": "string" },
        "retrieved_at": { "type": "string" },
        "trust_level": { "enum": ["official", "public_directory", "provided", "derived", "unverified"] },
        "license_or_permission": { "type": "string" }
      }
    },
    "Product": {
      "allOf": [
        { "$ref": "#/$defs/EntityBase" },
        {
          "type": "object",
          "required": ["name", "category"],
          "properties": {
            "name": { "type": "string" },
            "category": { "type": "string" },
            "description": { "type": "string" },
            "price": { "type": ["number", "null"] },
            "image_url": { "type": ["string", "null"] }
          }
        }
      ]
    },
    "Account": {
      "allOf": [
        { "$ref": "#/$defs/EntityBase" },
        {
          "type": "object",
          "required": ["name", "segment"],
          "properties": {
            "name": { "type": "string" },
            "segment": { "type": "string" },
            "website": { "type": ["string", "null"] },
            "address": { "type": ["string", "null"] }
          }
        }
      ]
    },
    "Contact": {
      "allOf": [
        { "$ref": "#/$defs/EntityBase" },
        {
          "type": "object",
          "required": ["account_id", "name"],
          "properties": {
            "account_id": { "type": "string" },
            "name": { "type": "string" },
            "role": { "type": ["string", "null"] },
            "email": { "type": ["string", "null"] },
            "phone": { "type": ["string", "null"] }
          }
        }
      ]
    },
    "Opportunity": {
      "allOf": [
        { "$ref": "#/$defs/EntityBase" },
        {
          "type": "object",
          "required": ["account_id", "stage", "value"],
          "properties": {
            "account_id": { "type": "string" },
            "stage": { "type": "string" },
            "value": { "type": "number" },
            "next_action": { "type": ["string", "null"] }
          }
        }
      ]
    },
    "AgentRun": {
      "type": "object",
      "required": ["id", "agent_id", "task", "status", "started_at"],
      "properties": {
        "id": { "type": "string" },
        "agent_id": { "type": "string" },
        "task": { "type": "string" },
        "status": { "enum": ["queued", "running", "needs_review", "completed", "failed", "blocked"] },
        "started_at": { "type": "string" },
        "finished_at": { "type": ["string", "null"] }
      }
    },
    "AuditEvent": {
      "type": "object",
      "required": ["id", "actor", "action", "target", "created_at"],
      "properties": {
        "id": { "type": "string" },
        "actor": { "type": "string" },
        "action": { "type": "string" },
        "target": { "type": "string" },
        "created_at": { "type": "string" }
      }
    }
  }
}
